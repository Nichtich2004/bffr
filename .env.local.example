# Set to 'true' to use mock Shopify products for local development
# Set to 'false' to connect to a real Shopify store
SHOPIFY_USE_MOCK=

# Shopify Store Domain (e.g., mystore.myshopify.com)
# Required when SHOPIFY_USE_MOCK is set to 'false'
SHOPIFY_STORE_DOMAIN=

# Shopify Storefront Access Token
# Required when SHOPIFY_USE_MOCK is set to 'false'
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
